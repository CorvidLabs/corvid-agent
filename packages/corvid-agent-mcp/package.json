{
  "name": "@corvid-agent/mcp",
  "version": "0.1.0",
  "description": "MCP server that exposes the corvid-agent REST API as MCP tools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "corvid-agent-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "corvid-agent",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "claude"
  ],
  "author": "CorvidLabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CorvidLabs/corvid-agent.git",
    "directory": "packages/corvid-agent-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
