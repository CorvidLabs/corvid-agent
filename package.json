{
  "name": "corvid-agent",
  "version": "0.58.0",
  "description": "AI agent framework with on-chain identity and messaging via AlgoChat on Algorand",
  "repository": {
    "type": "git",
    "url": "https://github.com/CorvidLabs/corvid-agent.git"
  },
  "homepage": "https://github.com/CorvidLabs/corvid-agent",
  "author": "CorvidLabs",
  "license": "MIT",
  "type": "module",
  "bin": {
    "corvid-agent": "./bin/corvid-agent.mjs"
  },
  "scripts": {
    "setup": "bun cli/index.ts init",
    "try": "bun scripts/try.ts",
    "dev": "bun --watch server/index.ts",
    "start": "bun server/index.ts",
    "test": "bun test",
    "test:e2e": "npx playwright test --config=playwright.config.js",
    "test:e2e:ui": "npx playwright test --config=playwright.config.js --ui",
    "build:client": "cd client && bun run build",
    "dev:client": "cd client && bun run start",
    "migrate": "bun server/db/migrate-cli.ts",
    "migrate:up": "bun server/db/migrate-cli.ts up",
    "migrate:down": "bun server/db/migrate-cli.ts down",
    "migrate:status": "bun server/db/migrate-cli.ts status",
    "migrate:create": "bun server/db/migrate-create.ts",
    "spec:check": "bash scripts/specsync.sh check",
    "spec:coverage": "bash scripts/specsync.sh coverage",
    "spec:coverage:require": "bash scripts/specsync.sh check --require-coverage 100",
    "spec:generate": "bash scripts/specsync.sh generate",
    "spec:score": "bash scripts/specsync.sh score",
    "spec:watch": "bash scripts/specsync.sh watch",
    "spec:resolve": "bash scripts/specsync.sh resolve",
    "openapi:validate": "bun scripts/openapi-validate.ts",
    "openapi:export": "bun scripts/openapi-validate.ts --export",
    "lint:sql": "bash scripts/check-sql-injection.sh",
    "rc:check": "bun scripts/rc-checklist.ts",
    "security:scan": "bun scripts/ci-security-scan.ts",
    "stats:check": "bun scripts/collect-stats.ts",
    "stats:update": "bun scripts/collect-stats.ts --update",
    "version:check": "bun scripts/version-check.ts",
    "migrate:keys": "bun scripts/migrate-keys.ts",
    "purge:test-data": "bun scripts/purge-test-data.ts",
    "governance:check": "bun scripts/governance-check.ts",
    "mcp": "bun server/mcp/stdio-server.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format .",
    "format:fix": "biome format --fix .",
    "localnet:fund": "bun scripts/localnet-fund.ts"
  },
  "optionalDependencies": {
    "@corvidlabs/ts-algochat": "^0.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-prometheus": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "algosdk": "^3.5.2",
    "croner": "^10.0.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.3.6"
  },
  "patchedDependencies": {},
  "overrides": {
    "minimatch": ">=9.0.7",
    "ajv": ">=8.18.0",
    "qs": ">=6.14.2",
    "hono": ">=4.12.7",
    "@hono/node-server": ">=1.19.10",
    "express-rate-limit": ">=8.2.2"
  }
}
